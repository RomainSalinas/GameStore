@page "/addgame"
@using Game_Library.Services
@using Microsoft.AspNetCore.Components.Forms

@rendermode InteractiveServer

@inject GameService GameService
@inject GenreService GenreService
@inject NavigationManager NavigationManager
<PageTitle>Add Game</PageTitle>

<h1>Add a new game to your library</h1>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <p>Loading...</p>
}

@code {
    
    private Game newGame = new Game() { ReleaseDate = DateOnly.FromDateTime(DateTime.Today) };
    private List<Genre> Genres = new List<Genre>();
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    
    private async Task NewGameAdded()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            await GameService.AddGameAsync(newGame);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error adding game: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Genres = await GenreService.GetGenresAsync();
    }
}

<EditForm Model="newGame" OnSubmit="NewGameAdded" class="mt-4" FormName="addGameForm">
    <DataAnnotationsValidator />
    <div class="mb-3">
        <label for="gameName" class="form-label">Game Name</label>
        <InputText @bind-Value="newGame.Name" class="form-control" id="gameName" />
        <ValidationMessage For="() => newGame.Name" />
    </div>
    <div class="mb-3">
        <label for="gameGenre" class="form-label">Genre</label>
        <InputSelect @bind-Value="newGame.GenreId" class="form-control" id="gameGenre">
            <option value="0">Select a genre</option>
            @foreach (var genre in Genres)
            {
                <option value="@genre.Id">@genre.Name</option>
            }
        </InputSelect>
        <ValidationMessage For="() => newGame.GenreId" />
    </div>
    <div class="mb-3">
        <label for="gamePrice" class="form-label">Price</label>
        <InputNumber @bind-Value="newGame.Price" step="0.01" class="form-control" id="gamePrice" />
        <ValidationMessage For="() => newGame.Price" />
    </div>
    <div class="mb-3">
        <label for="gameReleaseDate" class="form-label">Release Date</label>
        <InputDate @bind-Value="newGame.ReleaseDate" class="form-control" id="gameReleaseDate" />
        <ValidationMessage For="() => newGame.ReleaseDate" />
    </div>
    <button type="submit" class="btn btn-primary" disabled="@(isLoading || newGame.GenreId == 0 || newGame.Price <= 0)">Add Game</button>
</EditForm>